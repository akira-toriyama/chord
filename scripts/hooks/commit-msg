#!/usr/bin/env bash
# chord commit-msg hook — validates gitmoji + Conventional Commits.
#
# Install:
#   git config core.hooksPath scripts/hooks
#
# See docs/commit-convention.md for the grammar.

set -euo pipefail

msg_file="$1"
first_line="$(head -n1 "$msg_file" | sed 's/[[:space:]]*$//')"

# Allow merge / revert / fixup commits Git generates itself.
case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0 ;;
esac

# Pattern: :gitmoji: type(scope)!: subject
#          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
re='^:[a-z0-9_+-]+:[[:space:]]+(feat|fix|docs|test|refactor|perf|build|ci|chore|revert|style)(\([a-z0-9_/-]+\))?(!)?:[[:space:]]+.+$'

if [[ ! "$first_line" =~ $re ]]; then
  cat <<EOF >&2
chord: commit message does not match the gitmoji + Conventional Commits
       convention. See docs/commit-convention.md.

Got:    $first_line
Expect: :sparkles: feat(core): your subject here

Common gitmojis: :sparkles: (feat) :bug: (fix) :memo: (docs)
                 :test_tube: (test) :recycle: (refactor)
EOF
  exit 1
fi
