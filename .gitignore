.DS_Store

# SwiftPM build artefacts
.build/
.swiftpm/
# Package.resolved IS tracked since chord gained its first external
# dependency (sill's `Toml` module, atelier Phase 1.6) — pinning the
# exact commit gives reproducible release/CI builds, matching the
# family's other executables (perch / wand).

# setup-signing-cert.sh writes the local identity name here; each
# developer regenerates their own. Don't commit.
.signing-id

# Bundles assembled by package.sh
Chord.app/
Chord-dev.app/
dist/

# Generated icon intermediates (the AppIcon.appiconset/* PNGs are
# committed; the .iconset/ directory is the staging area for
# iconutil and can be regenerated by scripts/gen-icon.swift).
assets/icon/chord.iconset/
assets/icon/chord.icns

# Editor / OS noise
.vscode/
.idea/
*.xcodeproj/xcuserdata/

# Local secret / cred files
.env
.env.local

# Logs from foreground debug runs
/tmp/chord*.log
*.log
